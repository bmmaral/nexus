<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>gittriage</id>
    <version>0.1.0</version>
    <title>GitTriage CLI</title>
    <authors>GitTriage contributors</authors>
    <projectUrl>https://github.com/bmmaral/gittriage</projectUrl>
    <licenseUrl>https://github.com/bmmaral/gittriage/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectSourceUrl>https://github.com/bmmaral/gittriage</projectSourceUrl>
    <docsUrl>https://github.com/bmmaral/gittriage/tree/main/docs</docsUrl>
    <bugTrackerUrl>https://github.com/bmmaral/gittriage/issues</bugTrackerUrl>
    <tags>gittriage git cli fleet triage</tags>
    <summary>Local-first repo fleet triage CLI</summary>
    <description>
      GitTriage inventories local git clones, clusters them, scores, and writes a plan — read-only by default.
      This package installs the prebuilt Windows binary from GitHub Releases.
    </description>
    <releaseNotes>https://github.com/bmmaral/gittriage/releases</releaseNotes>
  </metadata>
  <files>
    <file src="tools/**" target="tools" />
  </files>
</package>
