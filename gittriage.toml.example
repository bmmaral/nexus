# Local-only; `.gittriage/` is gitignored — do not commit the database.
db_path = ".gittriage/state.db"
default_roots = ["~/Projects", "~/code"]
github_owner = "your-github-login"
include_hidden = false

[scan]
respect_gitignore = true
max_readme_bytes = 16384
max_hash_files = 64
# scan_mode = "git_only"    # "git_only" (default) or "project_roots"
# max_depth = 5             # optional: limit directory traversal depth

[planner]
archive_duplicate_threshold = 80
oss_candidate_threshold = 70
# Ambiguous when planner confidence is below this percent (default 60 matches the historical 0.6 cutoff).
ambiguous_cluster_threshold = 60
# Optional: exact clone IDs from `gittriage score --format json` to force as canonical within their cluster.
# canonical_pins = ["clone-uuid-here"]
# ignored_cluster_keys = ["name:experiment"]
# archive_hint_cluster_keys = ["name:old-checkout"]
# scoring_profile = "default"

# Optional AI-assisted explanations (requires GITTRIAGE_AI_API_KEY or OPENAI_API_KEY).
# [ai]
# enabled = false
# api_base = "https://api.openai.com/v1"
# model = "gpt-4o-mini"
# max_tokens = 1024
# temperature = 0.2
